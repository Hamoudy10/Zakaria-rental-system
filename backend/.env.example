# ====================================================================
# NEVER commit this file to git. Copy to .env and fill in your values.
# The real .env is in .gitignore.
# ====================================================================

# Server
PORT=3001
NODE_ENV=development

# Database (Supabase PostgreSQL)
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.xxxxx
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=generate_a_random_secret_here
JWT_EXPIRES_IN=7d

# Frontend
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# M-Pesa (Safaricom Daraja API)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORT_CODE=4011461
MPESA_PAYBILL_NUMBER=4011461
MPESA_PASSKEY=your_passkey
MPESA_ENVIRONMENT=sandbox
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=https://your-backend.com/api/payments/c2b/callback
MPESA_VALIDATION_URL=https://your-backend.com/api/payments/c2b/validation
MPESA_ACCOUNT_REFERENCE=RENTAL_PAYMENT
MPESA_C2B_REGISTER_VERSION=v2
MPESA_STRICT_SOURCE_VERIFICATION=false

# SMS (Celcom Africa)
SMS_PARTNER_ID=your_partner_id
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=ZakariaAgcy
SMS_BASE_URL=https://isms.celcomafrica.com/api/services/sendsms/

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token

# Email (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=465
SMTP_USER=your_smtp_login
SMTP_PASS=your_smtp_key
EMAIL_FROM=yourname@gmail.com
APP_NAME=Zakaria Rental System
RESET_TOKEN_EXPIRY_MINUTES=60

# AI Agent (DeepSeek — primary; Groq fallback supported)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Optional: per-task model overrides
# DEEPSEEK_ROUTER_MODEL=deepseek-chat
# DEEPSEEK_NARRATIVE_MODEL=deepseek-chat
# DEEPSEEK_SQL_MODEL=deepseek-chat
# Legacy Groq fallback (optional):
# GROQ_API_KEY=your_groq_api_key
# GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_DYNAMIC_SQL_ENABLED=true
